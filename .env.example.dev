# Development (lokalt): kopiera till `.env` i repo-root.
#
# OBS: `.env` laddas av `src/projektveckor_portal/settings.py` i dev-läge.
# Lägg inga hemligheter i git ( `.env` är gitignored).

PVP_ENVIRONMENT=dev

# Doc library / exports (lokalt)
PVP_DOCS_ROOT="data/doclib"
PVP_EXPORTS_ROOT="data/exports"

# Auth (HuleEdu Identity Service)
#
# Rekommendation:
# - För autentiserings-smoke-test med riktiga cookies/CSRF: kör portalen på Hemma via `compose.prod.yaml`.
# - Om du ändå vill utveckla lokalt mot Hemma: använd en explicit, godkänd tunnel/proxy och peka hit.
PVP_IDENTITY_BASE_URL=""
PVP_IDENTITY_INTROSPECT_URL=""

# Cookies (lokalt över http)
PVP_COOKIE_SECURE=false
PVP_COOKIE_SAMESITE=lax

# Sir Convert a Lot (v2)
#
# Rekommendation:
# - För export-smoke-test: kör portalen på Hemma via `compose.prod.yaml`.
PVP_SIR_CONVERT_A_LOT_BASE_URL=""
PVP_SIR_CONVERT_A_LOT_API_KEY=""
