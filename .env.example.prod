# Production (Hemma): kopiera till `.env` på servern.
#
# OBS: Lokalt (dev) använder backend också `.env`, men med helt andra värden (se `.env.example.dev`).
# Blanda inte ihop din lokala `.env` med serverns `.env`.
VIRTUAL_HOST=projektveckor.hule.education
LETSENCRYPT_HOST=projektveckor.hule.education
# Doc library / exports
PVP_DOCS_ROOT="data/doclib"
PVP_EXPORTS_ROOT="data/exports"

# Auth (HuleEdu Identity Service)
# Base URL (utan trailing path).
# Hemma (internt i `hule-network`): `http://huleedu_identity_service:7005`
PVP_IDENTITY_BASE_URL="http://huleedu_identity_service:7005"
# Optional: om tom används `${PVP_IDENTITY_BASE_URL}/v1/auth/introspect`
PVP_IDENTITY_INTROSPECT_URL=""

# Cookies (host-only i nuläget: sätt ingen DOMAIN)
PVP_COOKIE_SECURE=true
PVP_COOKIE_SAMESITE=lax
PVP_AUTH_ACCESS_COOKIE_NAME=pvp_access_token
PVP_AUTH_REFRESH_COOKIE_NAME=pvp_refresh_token
PVP_CSRF_COOKIE_NAME=pvp_csrf_token

# Sir Convert a Lot (v2)
# Rekommenderat på hemma-servern:
# - kör tjänsten på samma host och på samma interna Docker-nät (t.ex. `hule-network`)
# - exponera inte med egen `VIRTUAL_HOST` (dvs endast intern åtkomst från portalens container)
# - behåll API-key (defense-in-depth)
#
# Exempel (intern service-adress i Docker-nät):
# PVP_SIR_CONVERT_A_LOT_BASE_URL="http://sir_convert_a_lot_prod:8085"
PVP_SIR_CONVERT_A_LOT_BASE_URL="http://sir_convert_a_lot_prod:8085"
PVP_SIR_CONVERT_A_LOT_API_KEY=""
